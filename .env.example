# Coolify'a bu değişkenleri gir (Environment Variables sekmesi)

# PostgreSQL — Coolify'da yeni DB oluşturduktan sonra al
DATABASE_URL="postgresql://leadauto_user:PASSWORD@HOST:5432/leadauto"

# NextAuth
NEXTAUTH_URL="https://leadauto.senindomain.com"
NEXTAUTH_SECRET=""   # openssl rand -hex 32

# Google OAuth (console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Places API (Maps Platform → Places API etkinleştir)
GOOGLE_PLACES_API_KEY=""

# Gmail (Gmail → Settings → 2FA → App Password)
GMAIL_USER="leadauto@gmail.com"
GMAIL_APP_PASSWORD=""

# Anthropic
ANTHROPIC_API_KEY=""

# App URL (Coolify'ın verdiği domain)
NEXT_PUBLIC_APP_URL="https://leadauto.senindomain.com"

# Redis — docker-compose içi, değiştirme
REDIS_URL="redis://redis:6379"

# WhatsApp Cloud API (Meta Business Manager → WhatsApp → API Setup)
# Template mesajı Meta tarafından onaylanmış olmalı, 2 body param almalı: firma adı, demo linki
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_NAME=""
