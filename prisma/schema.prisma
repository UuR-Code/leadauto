generator client {
  provider   = "prisma-client-js"
  engineType = "client"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  sector      String
  city        String
  district    String
  channel          String         @default("email")
  targetCount      Int            @default(100)
  requireNoWebsite Boolean        @default(true)
  status           CampaignStatus @default(RUNNING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  firms       Firm[]
}

enum CampaignStatus {
  RUNNING
  PAUSED
  COMPLETED
}

model Firm {
  id            String     @id @default(cuid())
  campaignId    String
  campaign      Campaign   @relation(fields: [campaignId], references: [id])
  name          String
  address       String
  phone         String?
  email         String?
  category      String
  city          String
  district      String
  lat           Float?
  lng           Float?
  placeId       String?    @unique
  photoUrl      String?
  status        FirmStatus @default(SCRAPED)
  demoUrl       String?
  demoSlug      String?    @unique
  viewCount     Int        @default(0)
  deployedAt    DateTime?
  emailSentAt   DateTime?
  followupSentAt DateTime?
  repliedAt     DateTime?
  replyText     String?    @db.Text
  meetingAt     DateTime?
  meetingNote   String?    @db.Text
  closedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  landingPage LandingPage?
  emails      EmailLog[]
  leads       Lead[]
}

enum FirmStatus {
  SCRAPED
  PAGE_READY
  DEPLOYED
  SENT
  REPLIED
  MEETING
  CLOSED
  SKIPPED
}

model LandingPage {
  id              String   @id @default(cuid())
  firmId          String   @unique
  firm            Firm     @relation(fields: [firmId], references: [id])
  heroTitle       String
  heroSub         String   @db.Text
  services        Json
  aboutText       String   @db.Text
  ctaText         String
  colorPrimary    String   @default("#2563eb")
  blueprint       Json?
  vercelProjectId String?
  createdAt       DateTime @default(now())
}

model EmailLog {
  id        String      @id @default(cuid())
  firmId    String
  firm      Firm        @relation(fields: [firmId], references: [id])
  to        String
  subject   String
  status    EmailStatus @default(PENDING)
  messageId String?
  openedAt  DateTime?
  clickedAt DateTime?
  sentAt    DateTime?
  error     String?
  createdAt DateTime    @default(now())
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  OPENED
  CLICKED
}

model Lead {
  id        String   @id @default(cuid())
  firmId    String
  firm      Firm     @relation(fields: [firmId], references: [id])
  name      String
  phone     String
  message   String?  @db.Text
  createdAt DateTime @default(now())
}

model Suppression {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}
